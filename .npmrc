save-exact=true      # salva versão exata no package.json (sem ^ ou ~)
ignore-scripts=true  # bloqueia execução de scripts do package.json (preinstall, postinstall etc.) durante npm install
min-release-age=7    # ⚠️ não é opção nativa do npm — sem efeito; provavelmente intenção era exigir pacotes com ≥7 dias de publicação (requer ferramenta externa como Socket.dev)
allow-git=none       # ⚠️ não é opção nativa do npm — sem efeito; para bloquear git-deps use uma ferramenta de lint de lockfile ou política de CI